# Copy this file to `.env` in the sample root (message-store-processor/solace-sap-s4hana/,
# where docker-compose.yml lives) and fill in your Datadog API key.
# docker compose auto-loads `.env` from that directory. From the sample root:
#
#   cp datadog/.env.example .env
#
# Create an API key at: Datadog > Organization Settings > API Keys
# `.env` is gitignored so your key is never committed.
DD_API_KEY=

# Datadog site for your account. Change if your org is on another site
# (e.g. datadoghq.eu, us5.datadoghq.com).
DD_SITE=datadoghq.com

# Default service tag applied to telemetry emitted by the Agent itself.
DD_SERVICE=solace-sap-s4hana
